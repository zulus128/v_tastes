{
  "name": "@tastes/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tastes/contracts": "workspace:*",
    "@tastes/firebase-client": "workspace:*",
    "expo": "~57.0.7",
    "expo-dev-client": "~57.0.7",
    "expo-linear-gradient": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "firebase": "^12.6.0",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start --dev-client --port 8082",
    "android": "expo start --dev-client --android --port 8082",
    "ios": "expo start --dev-client --ios --port 8082",
    "build:android": "expo run:android --no-bundler --port 8082",
    "build:ios": "expo run:ios --no-bundler --port 8082",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "private": true
}
